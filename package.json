{
  "name": "cloudhood",
  "version": "1.10.0",
  "type": "module",
  "author": "Cloud technology Limited (Ltd.)",
  "url": "https://cloud.ru/",
  "license": "Apache-2.0",
  "scripts": {
    "build:license-validator": "cd ./.license-validator && pnpm build",
    "check-license": "pnpx ./.license-validator -i",
    "build:chromium": "BROWSER=chrome vite build && BROWSER=chrome vite build --config vite.background.config.ts",
    "build:firefox": "BROWSER=firefox vite build && BROWSER=firefox vite build --config vite.background.config.ts",
    "build:firefox-sources": "node scripts/build-firefox-sources.mjs",
    "check:chrome-build": "node scripts/check-extension-builds.mjs chrome",
    "check:firefox-build": "node scripts/check-extension-builds.mjs firefox",
    "check:extension-builds": "node scripts/check-extension-builds.mjs",
    "build": "pnpm build:chromium && pnpm build:firefox",
    "dev:chrome": "node scripts/dev-server.mjs",
    "dev:firefox": "concurrently --names \"WS,BUILD\" --prefix-colors \"blue,green\" \"node scripts/simple-reload-server.mjs\" \"BROWSER=firefox vite build --watch --mode development\"",
    "dev:setup": "node scripts/dev-setup.cjs",
    "lint": "npx eslint ./src",
    "lint:css": "npx stylelint \"./src/**/*.{css,styled.ts}\" --config stylelint.config.cjs",
    "test:unit": "node --max-old-space-size=4096 node_modules/vitest/vitest.mjs run",
    "prepare": "husky",
    "tsc": "npx tsc --noEmit --emitDeclarationOnly false",
    "reinstall": "rm -rf node_modules && rm -rf pnpm-lock.yaml && pnpm install",
    "test:e2e": "HEADLESS=false playwright test --project=chrome-extension",
    "test:e2e:ci": "HEADLESS=true playwright test --project=chrome-extension --reporter=line --max-failures=2",
    "test:e2e:firefox": "node scripts/firefox-e2e.mjs",
    "test:e2e:firefox:docker": "docker compose -f docker-compose.screenshots.yml run --rm screenshots sh -lc \"pnpm install --frozen-lockfile && pnpm build:firefox && pnpm test:e2e:firefox\"",
    "test:e2e:screenshots": "pnpm test:e2e:screenshots:chrome && pnpm test:e2e:screenshots:firefox",
    "test:e2e:screenshots:update": "pnpm test:e2e:screenshots:chrome:update && pnpm test:e2e:screenshots:firefox:update",
    "test:e2e:screenshots:chrome": "playwright test --project=chrome-screenshots",
    "test:e2e:screenshots:chrome:update": "playwright test --project=chrome-screenshots --update-snapshots",
    "test:e2e:screenshots:firefox": "node scripts/firefox-screenshots.mjs",
    "test:e2e:screenshots:firefox:update": "node scripts/firefox-screenshots.mjs --update-snapshots",
    "docker:screenshots:build": "docker compose -f docker-compose.screenshots.yml build screenshots",
    "test:e2e:screenshots:docker": "docker compose -f docker-compose.screenshots.yml run --rm screenshots sh -lc \"pnpm install --frozen-lockfile && pnpm build && pnpm test:e2e:screenshots\"",
    "test:e2e:screenshots:docker:update": "docker compose -f docker-compose.screenshots.yml run --rm screenshots sh -lc \"pnpm install --frozen-lockfile && pnpm build && pnpm test:e2e:screenshots:update\"",
    "test:e2e:screenshots:check": "pnpm test:e2e:screenshots:docker",
    "test:e2e:screenshots:generate": "pnpm test:e2e:screenshots:docker:update"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@snack-uikit/button": "0.19.19",
    "@snack-uikit/divider": "3.2.12",
    "@snack-uikit/drop-zone": "0.9.12",
    "@snack-uikit/fields": "0.57.1",
    "@snack-uikit/figma-tokens": "17.7.5",
    "@snack-uikit/icons": "0.27.7",
    "@snack-uikit/list": "0.33.2",
    "@snack-uikit/modal": "0.20.1",
    "@snack-uikit/tabs": "0.10.19",
    "@snack-uikit/toaster": "0.11.29",
    "@snack-uikit/toggles": "0.13.27",
    "@snack-uikit/tooltip": "0.18.14",
    "@snack-uikit/truncate-string": "0.7.13",
    "effector": "23.4.4",
    "effector-react": "23.3.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@cloud-ru/eslint-config": "3.1.6",
    "@cloud-ru/ft-config-commit-message": "1.1.2",
    "@cloud-ru/ft-config-lint-staged": "1.1.4",
    "@cloud-ru/ft-config-stylelint": "3.1.2",
    "@cloud-ru/ft-config-vitest": "1.3.3",
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/compat": "2.1.0",
    "@playwright/test": "1.61.1",
    "@svgr/webpack": "8.1.0",
    "@types/node": "26.1.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@types/webextension-polyfill": "0.12.5",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "10.0.3",
    "eslint-plugin-effector": "0.19.0",
    "fs-extra": "11.3.6",
    "geckodriver": "6.1.0",
    "husky": "^9.1.6",
    "jsdom": "29.1.1",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "postcss-styled-syntax": "0.7.2",
    "prettier": "3.9.4",
    "selenium-webdriver": "4.45.0",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-svgr": "5.2.0",
    "vite-tsconfig-paths": "6.1.1",
    "webextension-polyfill": "0.12.0",
    "ws": "8.21.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs": "7.29.4",
      "brace-expansion": "2.0.3",
      "esbuild": "0.27.2",
      "fast-uri": "3.1.2",
      "flatted": "3.4.2",
      "glob": "10.5.0",
      "minimatch": "9.0.9",
      "@eslint/eslintrc>minimatch": "3.1.5",
      "picomatch": "4.0.4",
      "postcss": "8.5.10",
      "rollup": "4.60.1",
      "svgo": "3.3.3",
      "yaml": "1.10.3"
    }
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": "^10.10.0"
  },
  "homepage": "https://github.com/cloud-ru-tech/cloudhood"
}
